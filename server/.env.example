DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"
# Use a long random secret. In production (NODE_ENV=production) the server requires at least 32 characters.
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars-for-prod"
WEB_ORIGIN="http://localhost:5173"
PORT=3000

# Optional auth tuning
# JWT_ACCESS_MINUTES=15
# REFRESH_TOKEN_DAYS=14

# Password reset emails (Resend) — required for real emails in production
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=Team Task Manager <onboarding@resend.dev>

# Railway / reverse proxy: forward correct client IP for rate limiting
# TRUST_PROXY=1

# Force Secure cookies (defaults true when NODE_ENV=production)
# COOKIE_SECURE=true
